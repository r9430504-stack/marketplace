{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "npx prisma db push; npx next start -p ${PORT:-3000}",
    "healthcheckPath": "/api/auth/me",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE"
  }
}
